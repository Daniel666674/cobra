# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cobra
DB_USER=cobra_user
DB_PASS=change_me_in_production

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── WhatsApp Business API ────────────────────────────
# Leave blank → mock mode (logs to console, never sends real messages)
WA_TOKEN=
WA_PHONE_ID=
WA_VERIFY_TOKEN=cobra_webhook_verify

# ─── Dapta AI Voice ───────────────────────────────────
# Leave blank → mock mode
DAPTA_API_KEY=
DAPTA_AGENT_ID=

# ─── Bold / Wompi Payments ────────────────────────────
# Leave blank → mock mode (returns fake payment links)
BOLD_SECRET_KEY=
BOLD_INTEGRITY_KEY=

# ─── Alegra Invoicing ─────────────────────────────────
# Leave blank → mock mode (returns fake FE numbers)
ALEGRA_USER=
ALEGRA_TOKEN=

# ─── Compliance (Ley 2300) ────────────────────────────
CONTACT_HOUR_START=7
CONTACT_HOUR_END=20
MAX_DAILY_CONTACTS=2
